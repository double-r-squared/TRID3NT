{
  "$defs": {
    "PipelineStep": {
      "additionalProperties": false,
      "description": "One step in the pipeline snapshot.\n\n``duration_ms`` (job-0264, ELEVATED tool-timer requirement) is the\nauthoritative wall-clock elapsed time the workflow stamps on the\n**terminal** transition (complete / failed / cancelled). It is derived\ndeterministically from ``completed_at - started_at`` by the\n``PipelineEmitter`` \u2014 NOT an LLM estimate (Invariant 1). Optional and\n``None`` for pending/running steps: the client renders a cosmetic live\nticker until this lands, then locks the card to this number. Milliseconds\nso a sub-second tool reads honestly (0 displays as \"0:00\"). ``ge=0``.",
      "properties": {
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "duration_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "progress_percent": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Progress Percent"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "state": {
          "enum": [
            "pending",
            "running",
            "complete",
            "failed",
            "cancelled"
          ],
          "title": "State",
          "type": "string"
        },
        "step_id": {
          "title": "Step Id",
          "type": "string"
        },
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "name",
        "tool_name",
        "state"
      ],
      "title": "PipelineStep",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "``pipeline-state`` (A.4): full snapshot of the current pipeline.\n\nThe full snapshot replaces the client's pipeline view on each message;\ndeltas are not used.",
  "properties": {
    "pipeline_id": {
      "title": "Pipeline Id",
      "type": "string"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/PipelineStep"
      },
      "title": "Steps",
      "type": "array"
    }
  },
  "required": [
    "pipeline_id"
  ],
  "title": "PipelineStatePayload",
  "type": "object"
}
