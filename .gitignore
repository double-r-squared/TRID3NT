# GRACE-2 — version-control ignores (SRS v0.3 stack).
#
# PUBLIC REPOSITORY: this repo is public. Every credential, key, token, or
# secret-bearing artifact MUST be ignored here FIRST before being created
# locally. New sensitive-content patterns belong in the "secrets / credentials"
# section below (or in a more specific section that already exists).
#
# Intentional inclusions (do NOT add ignore rules that would shadow these):
#   - infra/.terraform.lock.hcl       (provider-version reproducibility)
#   - infra/*.tfvars.example          (template; real *.tfvars stays ignored)
#   - packages/contracts/schemas/*.json (generated JSON Schemas, not secrets)

# --- Python (agent service, PyQGIS/solver workers, contracts package) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
*.so
.Python
develop-eggs/
.installed.cfg
pip-wheel-metadata/
*.whl

# --- virtual / conda environments (the blessed local env is named, not vendored) ---
.venv*/
venv/
env/
.conda/

# --- Node / web client (React + MapLibre) ---
node_modules/
.npm/
.pnpm-store/
.yarn/
dist/
build/
.vite/
.next/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
.node_repl_history
.nyc_output/
lib-cov/

# --- Vite transient config (HMR writes these next to vite.config.ts) ---
vite.config.*.timestamp-*
vite.config.*.timestamp-*.mjs

# --- OpenTofu / Terraform (infra/) ---
.terraform/
# .terraform.lock.hcl is COMMITTED for provider-version reproducibility.
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
!*.tfvars.example
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.tofu/
*.tfplan
*.tfplan.*
tfplan
.terraform.tfstate.lock.info

# --- testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache/
coverage/

# --- Python type-checker & notebook caches ---
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/
.ipynb_checkpoints/
.nox/
*.pyd

# --- QGIS artifacts (local PyQGIS worker dev) ---
*.qmlc
*.qgs~
*.qgz~
*.qgs.gz~
.qgis2/
qgis_profile/

# --- QGIS / GeoPackage / SQLite sidecars (PyQGIS workers, M5+) ---
*.gpkg-journal
*.gpkg-shm
*.gpkg-wal
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# --- Local databases (never commit, even for dev) ---
*.sqlite
*.sqlite3
*.db
*.duckdb

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# --- Generic logs / pids / pip leftovers ---
*.log
*.log.*
pip-log.txt
pip-delete-this-directory.txt
*.pid
*.pid.lock
*.seed

# --- direnv / extra env file variants ---
.envrc
.direnv/

# --- temp / scratch (specialists sometimes stage at repo root) ---
tmp/
scratch/
/_tmp_*/

# ============================================================================
# secrets / credentials (NFR-S-2/S-3)
# Every credential goes through Secret Manager + Workload Identity. Nothing
# secret-bearing ever lives in the repo, in-tree, or baked into images.
# ============================================================================

# --- generic env files ---
.env
.env.*

# --- private keys (PEM, OpenSSH, others) ---
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore

# --- SSH private keys ---
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
known_hosts
authorized_keys

# --- GCP service-account keys / ADC ---
*-key.json
*_key.json
*-sa.json
gcp-*.json
service-account*.json
application_default_credentials.json
client_secret*.json
*-credentials.json
*-adc.json
gcloud-config-*
.gcloud/

# --- GitHub Actions / OIDC credential caches ---
gha-creds-*.json

# --- Kubernetes (future GKE) ---
kubeconfig
*.kubeconfig
.kube/

# --- Atlas CLI / MongoDB local artifacts ---
.atlascli/
atlas-cli.log
*.atlas-keys
mongosh_*.log
.mongorc.js

# --- MongoDB dump / SQL backup output (never commit local backups of real data) ---
*.bson
*.bson.gz
*.dump
*.sql
*.sql.gz

# --- generic "secrets" directories ---
secrets/
**/secrets/

# --- browser session captures (HAR routinely contains Authorization headers) ---
*.har
cookies.txt
*.session

# --- Docker (M3+ container builds) ---
docker-compose.override.yml
.docker/

# --- Claude Code session leakage (settings.json may be tracked; these never) ---
.claude/projects/
.claude/cache/
.claude/sessions/
.claude/todos/
.claude/settings.local.json

# --- Solver run output / large simulation artifacts (uncommented per the gitignore audit) ---
# These are reserved patterns. SFINCS / Pelicun / TELEMAC workers ship outputs
# to GCS; the repo never holds them. Uncomment the *.tif.aux.xml line if a
# specialist needs to track sidecar metadata for a specific run.
runs/
outputs/
*.nc
sfincs_*.dat
*.sgsg
# *.tif.aux.xml  (intentionally NOT ignored — sidecars may be useful evidence)

# --- Playwright dynamic captures (job-0027 + job-0028) ---
# `make ui-tour` writes per-run screenshots under tests/m3/artifacts/screenshots-*/
# (and the default ephemeral target /tmp/grace2-shots/, already covered by `tmp/`).
# `make test-m3` writes per-test PNGs into tests/m3/artifacts/ (the m3_artifacts_dir
# fixture in tests/m3/conftest.py); those are EPHEMERAL — the canonical evidence
# trail is committed under reports/inflight/<job>/evidence/.
# The canonical reference captures (tests/m3/artifacts/chromium-initial.png,
# tests/m3/artifacts/firefox-initial.png) are EXPLICITLY kept tracked — they are
# the M3 visual baseline.
tests/m3/artifacts/screenshots-*/
tests/m3/artifacts/*.png
!tests/m3/artifacts/chromium-initial.png
!tests/m3/artifacts/firefox-initial.png

# job-0298 housekeeping: loose secret + dead firebase config (public repo)
.nutshell-api-key

# Large solver/verify binaries must never be committed (GitHub 100MB hard limit;
# job-0308 push incident 2026-06-16 — MODFLOW mf6 binary + zips swept into reports/inflight).
**/mf6
**/mf6.*_linux/
**/mf6_dl/
**/mf6_extracted/
**/liveverify_adv/
reports/inflight/**/*.zip

# --- Dev evidence + exploratory spike scratch (accumulates during live debugging
#     / engine spikes; never shipped). The CANONICAL committed evidence trail
#     stays under reports/inflight/<job>/evidence/ — these rules are ANCHORED so
#     they do NOT shadow that. ---
/evidence/
/services/agent/evidence/
/services/workers/sfincs_quadtree_spike/
**/_spike_out/
/reports/inflight/p0_*
