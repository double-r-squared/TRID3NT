# GRACE-2 web — Vite environment variables (job-0123).
#
# Copy to `.env.local` (gitignored by Vite) and fill in real values from the
# Firebase console (https://console.firebase.google.com/) for the GRACE-2
# project. ALL VITE_* vars are exposed to the browser bundle — these are the
# Firebase "public" client config values and are SAFE to ship to clients
# (Firebase enforces security via Auth rules + Identity Platform IAM, not by
# hiding the API key — see Firebase docs § "Is it safe to expose Firebase API
# key to the public?").
#
# When VITE_FIREBASE_PROJECT_ID or VITE_FIREBASE_API_KEY are empty, the web
# client runs in anonymous-only mode: no Google sign-in available, the
# "Continue as anonymous" button works against the agent's anonymous
# fallback (no auth-token envelope is sent on connect).

# --- WebSocket endpoint (existing, M1 vintage) --------------------------- #
# Default ws://localhost:8765 (the local agent service from job-0015).
VITE_GRACE2_WS_URL=ws://localhost:8765

# --- Firebase Auth (job-0123, SRS Appendix H) ---------------------------- #
# Required for Google sign-in. All five vars must be set; missing any one
# falls back to anonymous-only mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
